{
    "version": 2,
    "builds": [
        {
            "src": "phase5/backend/main.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "phase5/backend/main.py"
        },
        {
            "src": "/(.*)",
            "dest": "phase5/backend/main.py"
        }
    ]
}